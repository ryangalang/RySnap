# Copy this file to .env.local and fill in your own Supabase project values.
# The app runs fully as a client-only demo (camera, capture, filters,
# stickers, download) with zero backend and none of these set.

# ── Client-side (safe to expose — these are public by design) ──
NEXT_PUBLIC_SUPABASE_URL=https://emyxgeooirrjrelvlzes.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVteXhnZW9vaXJyanJlbHZsemVzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQxMDA5NDIsImV4cCI6MjA5OTY3Njk0Mn0.4OyWYPxqfoStQUqozMdHRbsAVX37RNa-Ke1I4qaupVw

# ── Server-only — NEVER prefix with NEXT_PUBLIC_, never commit, never log ──
# Used only inside app/api/*/route.js. Bypasses Row Level Security, so it
# must stay server-side. Find it in Supabase: Project Settings → API →
# service_role key.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVteXhnZW9vaXJyanJlbHZsemVzIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4NDEwMDk0MiwiZXhwIjoyMDk5Njc2OTQyfQ.Eysjnqz_JVeBhJRXZ11ZQSX3tqvLHdJFtpTEFDPXa3U

# ── Optional: AI sticker generation (bring your own key) ──
# If set, the Decorate screen shows a "Generate a sticker" box that calls
# OpenAI's image API. Leave blank to hide that feature entirely.
OPENAI_API_KEY=
